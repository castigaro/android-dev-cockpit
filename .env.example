# Lokale Einstellungen. Kopie dieser Datei als ".env" wird von install.cmd
# automatisch angelegt. Die .env ist gitignoriert und bleibt auf diesem Rechner.
#
# Format: KEY=VALUE, keine Anführungszeichen, # leitet einen Kommentar ein.

# Wurzelverzeichnis, unter dem nach App-Repositories gesucht wird.
# Relativ zu diesem Repo oder absolut. Standard: das Elternverzeichnis,
# d. h. Geschwister-Ordner wie ../meine-app werden gefunden.
PROJECTS_ROOT=..

# Suchtiefe der App-Erkennung unterhalb von PROJECTS_ROOT.
# 3 findet sowohl <repo>/gradlew.bat als auch <repo>/apps/<app>/gradlew.bat.
DISCOVERY_DEPTH=3

# Zusätzliche Ordner für den generierten Workspace, die keine baubare App
# enthalten und deshalb nicht automatisch gefunden werden — z. B. ein
# Library-Repo mit gemeinsamem Code oder das Repo einer Website.
# Kommagetrennt, relativ zu PROJECTS_ROOT oder absolut. Standard: leer.
# WORKSPACE_EXTRA_DIRS=mein-common-repo,meine-website

# ---------------------------------------------------------------------------
# Android-SDK-Pakete. Nur ändern, wenn eine App ein neueres compileSdk braucht.
# ---------------------------------------------------------------------------
ANDROID_PLATFORM=34
ANDROID_BUILD_TOOLS=34.0.0

# ---------------------------------------------------------------------------
# Optional: lokal signierte Release-Builds.
#
# Für den normalen Debug-Loop NICHT nötig — Debug-Builds signiert Gradle
# automatisch mit einem eigenen Debug-Keystore.
#
# Trägst du beides ein, schaltet sich der Task "Release-APK lokal bauen
# (signiert)" frei. Der Keystore selbst gehört NICHT in dieses Repo, nur sein
# Pfad hierher.
# ---------------------------------------------------------------------------
# RELEASE_KEYSTORE_PATH=D:\secure\release.jks
# RELEASE_STORE_PASSWORD=
